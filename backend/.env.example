# Non-secret runtime configuration only.
# Secret values are forbidden here and must come from GCP Secret Manager.

COREADMIN_APP_NAME=CoreAdmin API
COREADMIN_ENVIRONMENT=local
COREADMIN_LOG_LEVEL=INFO
COREADMIN_GCP_PROJECT_ID=core-admin-tuskus
COREADMIN_GCP_SECRET_VERSION=latest
COREADMIN_SECRET_IDS=firebase-service-account-json,razorpay-key-id,razorpay-key-secret,razorpay-webhook-secret,jwt-signing-key
COREADMIN_FIREBASE_STORAGE_BUCKET=core-admin-tuskus.appspot.com
